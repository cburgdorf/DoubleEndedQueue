use std::abi::sol
use std::evm::{Evm, Address, Call, StorageMap, assert}
use ingot::Deque

msg DemoMsg {
    #[selector = sol("pushBackU(uint256)")]
    PushBackU { value: u256 },
    #[selector = sol("pushFrontU(uint256)")]
    PushFrontU { value: u256 },
    #[selector = sol("popBackU()")]
    PopBackU -> u256,
    #[selector = sol("popFrontU()")]
    PopFrontU -> u256,
    #[selector = sol("atU(uint256)")]
    AtU { index: u256 } -> u256,
    #[selector = sol("lenU()")]
    LenU -> u256,

    #[selector = sol("pushBackA(address)")]
    PushBackA { value: Address },
    #[selector = sol("popFrontA()")]
    PopFrontA -> Address,
    #[selector = sol("lenA()")]
    LenA -> u256,
}

struct Store {
    nums: Deque<u256>,
    addrs: Deque<Address>,
}

pub contract Demo {
    mut store: Store

    init() uses (mut store) {}

    recv DemoMsg {
        PushBackU { value } uses (mut store) {
            store.nums.push_back(value)
        }
        PushFrontU { value } uses (mut store) {
            store.nums.push_front(value)
        }
        PopBackU -> u256 uses (mut store) {
            store.nums.pop_back()
        }
        PopFrontU -> u256 uses (mut store) {
            store.nums.pop_front()
        }
        AtU { index } -> u256 uses (store) {
            store.nums.at(index)
        }
        LenU -> u256 uses (store) {
            store.nums.length()
        }

        PushBackA { value } uses (mut store) {
            store.addrs.push_back(value)
        }
        PopFrontA -> Address uses (mut store) {
            store.addrs.pop_front()
        }
        LenA -> u256 uses (store) {
            store.addrs.length()
        }
    }
}

const GAS: u256 = 1000000

fn deploy() -> Address uses (evm: mut Evm) {
    let addr = evm.create2<Demo>(value: 0, args: (), salt: 0)
    assert(addr.inner != 0)
    addr
}

#[test]
fn test_fifo_back_front() uses (evm: mut Evm) {
    let c = deploy()

    let len: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::LenU {})
    assert(len == 0)

    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 10 })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 20 })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 30 })

    let len: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::LenU {})
    assert(len == 3)

    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopFrontU {})
    assert(v == 10)
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopFrontU {})
    assert(v == 20)
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopFrontU {})
    assert(v == 30)

    let len: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::LenU {})
    assert(len == 0)
}

#[test]
fn test_lifo_back_back() uses (evm: mut Evm) {
    let c = deploy()

    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 1 })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 2 })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 3 })

    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopBackU {})
    assert(v == 3)
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopBackU {})
    assert(v == 2)
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopBackU {})
    assert(v == 1)
}

#[test]
fn test_push_front_then_indexed_access() uses (evm: mut Evm) {
    let c = deploy()

    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushFrontU { value: 100 })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushFrontU { value: 200 })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU  { value: 300 })

    // Layout after the three pushes: [200, 100, 300]
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::AtU { index: 0 })
    assert(v == 200)
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::AtU { index: 1 })
    assert(v == 100)
    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::AtU { index: 2 })
    assert(v == 300)
}

#[test]
fn test_independent_typed_deques() uses (evm: mut Evm) {
    // Same contract holds both a Deque<u256> and a Deque<Address>.
    // OZ's Bytes32Deque cannot do this without manual casts on every call.
    let c = deploy()

    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackU { value: 42 })
    let alice = Address { inner: 0xAAAA }
    let bob = Address { inner: 0xBBBB }
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackA { value: alice })
    evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PushBackA { value: bob })

    let len_u: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::LenU {})
    let len_a: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::LenA {})
    assert(len_u == 1)
    assert(len_a == 2)

    let v: u256 = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopBackU {})
    assert(v == 42)

    let a: Address = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopFrontA {})
    assert(a.inner == 0xAAAA)
    let a: Address = evm.call(addr: c, gas: GAS, value: 0, message: DemoMsg::PopFrontA {})
    assert(a.inner == 0xBBBB)
}
